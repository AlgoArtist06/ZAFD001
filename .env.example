# =============================================================================
# ZABR-008  Multilingual Legal Awareness Assistant  -  Environment Template
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the real values.
#   cp .env.example .env
# Before starting the Python backend:  set -a; source .env; set +a
# NEVER commit `.env` (it must stay git-ignored). Only this `.env.example`
# is tracked. Keys pasted here are placeholders, not real secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM  (Generation)  -  any OpenAI-compatible chat-completions endpoint
# Needed from: PHASE 1 (RAG core) onward.
# The default below is Google Gemini 2.5 Flash (free key at
# https://aistudio.google.com/apikey), but any OpenAI-compatible provider works
# by changing LLM_BASE_URL and LLM_MODEL - for example NVIDIA NIM
# (https://integrate.api.nvidia.com/v1, model qwen/qwen3-...) or OpenAI itself.
# NOTE: a free tier may use inputs to train the provider's model - this is
#       disclosed in the user privacy notice. Move to a paid no-training tier
#       for any real deployment.
# -----------------------------------------------------------------------------
LLM_PROVIDER=gemini
LLM_API_KEY=replace-with-llm-api-key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash


# -----------------------------------------------------------------------------
# Embeddings  -  LOCAL (FastEmbed / BGE).  No API key, runs on CPU, stays
# fully on-machine (zero privacy exposure). Retrieval is English-only by design.
# Needed from: PHASE 0 (ingestion).
#   bge-base-en-v1.5  -> EMBEDDING_DIM=768  (recommended)
#   bge-small-en-v1.5 -> EMBEDDING_DIM=384  (lighter/faster)
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIM=768


# -----------------------------------------------------------------------------
# Qdrant  (Vector store - legal documents ONLY)
# Needed from: PHASE 0 (ingestion).
# docker-compose.yml binds Qdrant to 127.0.0.1 and enforces this key server-side
# (QDRANT__SERVICE__API_KEY), so QDRANT_API_KEY is REQUIRED - the container
# refuses to start without it. Use a strong unique random value, e.g.
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Then set QDRANT_URL=http://localhost:6333 and QDRANT_API_KEY to the same value.
# -----------------------------------------------------------------------------
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=legal_documents


# -----------------------------------------------------------------------------
# Postgres  (App data - consent records and conversations; identities live in Clerk)
# Needed from: PHASE 3 (app shell).
# docker-compose.yml binds Postgres to 127.0.0.1 and reads these vars.
# POSTGRES_PASSWORD MUST be a strong unique value (the compose fallback
# "postgres" is dev-only and must never be used outside local development):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Keep DATABASE_URL's user/password/db in sync with the values below.
# -----------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=legal_assistant
# Example: postgresql://postgres:strong-password@localhost:5432/legal_assistant
DATABASE_URL=

# Encryption at rest for stored Conversation content (Fernet / AES). REQUIRED
# whenever DATABASE_URL is set outside development - without it the backend
# refuses to start rather than persist content with the offline stand-in cipher.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CONVERSATION_ENCRYPTION_KEY=


# -----------------------------------------------------------------------------
# Clerk  (Authentication)
# Needed from: PHASE 3 (app shell).
# Get keys at https://dashboard.clerk.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=replace-with-clerk-publishable-key
CLERK_SECRET_KEY=replace-with-clerk-secret-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up


# -----------------------------------------------------------------------------
# App wiring
# -----------------------------------------------------------------------------
APP_ENV=development
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
# The web app's origin, used to pin the backend's CORS allowlist. Leave empty in
# local development (the backend then allows any origin); set it to the deployed
# web URL (e.g. https://legal-saathi.example) in staging and production.
WEB_ORIGIN=


# -----------------------------------------------------------------------------
# RAG / pipeline tuning  (sensible defaults - change only if needed)
# -----------------------------------------------------------------------------
# Sections longer than this (in tokens) get split into sub-section child chunks;
# shorter sections stay whole. Parent expansion happens at query time.
CHUNK_TOKEN_THRESHOLD=512
# How many chunks to retrieve before parent expansion.
RETRIEVAL_TOP_K=8
# Hybrid search weighting: 0 = pure keyword/BM25, 1 = pure dense/vector.
HYBRID_ALPHA=0.5
# Supported languages: English, Hindi, Tamil, Gujarati.
SUPPORTED_LANGUAGES=en,hi,ta,gu
