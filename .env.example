# =============================================================================
# ZABR-008  Multilingual Legal Awareness Assistant  -  Environment Template
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the real values.
#   cp .env.example .env
# Before starting the Python backend:  set -a; source .env; set +a
# NEVER commit `.env` (it must stay git-ignored). Only this `.env.example`
# is tracked. Keys pasted here are placeholders, not real secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM  (Generation)  -  Google Gemini 2.5 Flash via OpenAI-compatible endpoint
# Needed from: PHASE 1 (RAG core) onward.
# Get a free key at https://aistudio.google.com/apikey
# NOTE: the free tier may use inputs to improve Google's products - this is
#       disclosed in the user privacy notice. Move to a paid no-training tier
#       for any real deployment.
# -----------------------------------------------------------------------------
LLM_PROVIDER=gemini
LLM_API_KEY=replace-with-gemini-api-key
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
LLM_MODEL=gemini-2.5-flash


# -----------------------------------------------------------------------------
# Embeddings  -  LOCAL (FastEmbed / BGE).  No API key, runs on CPU, stays
# fully on-machine (zero privacy exposure). Retrieval is English-only by design.
# Needed from: PHASE 0 (ingestion).
#   bge-base-en-v1.5  -> EMBEDDING_DIM=768  (recommended)
#   bge-small-en-v1.5 -> EMBEDDING_DIM=384  (lighter/faster)
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIM=768


# -----------------------------------------------------------------------------
# Qdrant  (Vector store - legal documents ONLY)
# Needed from: PHASE 0 (ingestion).
# Local Docker:  docker run -p 6333:6333 qdrant/qdrant
# Then set QDRANT_URL=http://localhost:6333 (leave API key empty).
# -----------------------------------------------------------------------------
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=legal_documents


# -----------------------------------------------------------------------------
# Postgres  (App data - users, auth/consent records, conversations)
# Needed from: PHASE 3 (app shell).
# -----------------------------------------------------------------------------
# Example: postgresql://postgres:postgres@localhost:5432/legal_assistant
DATABASE_URL=


# -----------------------------------------------------------------------------
# Clerk  (Authentication)
# Needed from: PHASE 3 (app shell).
# Get keys at https://dashboard.clerk.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=replace-with-clerk-publishable-key
CLERK_SECRET_KEY=replace-with-clerk-secret-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up


# -----------------------------------------------------------------------------
# App wiring
# -----------------------------------------------------------------------------
APP_ENV=development
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# RAG / pipeline tuning  (sensible defaults - change only if needed)
# -----------------------------------------------------------------------------
# Sections longer than this (in tokens) get split into sub-section child chunks;
# shorter sections stay whole. Parent expansion happens at query time.
CHUNK_TOKEN_THRESHOLD=512
# How many chunks to retrieve before parent expansion.
RETRIEVAL_TOP_K=8
# Hybrid search weighting: 0 = pure keyword/BM25, 1 = pure dense/vector.
HYBRID_ALPHA=0.5
# Supported languages: English, Hindi, Tamil, Gujarati.
SUPPORTED_LANGUAGES=en,hi,ta,gu
# Default conversation mode for new users: citizen | professional
DEFAULT_MODE=citizen
